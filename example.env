# Server and database
PORT=3000
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/sundarban_nova
JWT_SECRET=replace_with_a_long_random_secret

# Company information shown on the website and in booking emails
PERSON_NAME=Sundarban Nova Travels
PERSON_MOBILE=+919907947625
PERSON_ADDRESS=Godkhali Jetty, West Bengal 743370
PERSON_WEBSITE=http://localhost:3000

# Email delivery — use a Gmail App Password, not your normal Gmail password
EMAIL=your-business-email@gmail.com
EMAIL_PASSWORD=your_16_character_gmail_app_password
EMAIL_SERVICE=gmail

# First admin account — required only when running: npm run create-admin
ADMIN_NAME=Site Administrator
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_to_a_strong_password
