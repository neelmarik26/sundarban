<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>
    <%= typeof title !=='undefined' ? title : 'Sundarban Nova Travels' %>
  </title>
  <meta name="description"
    content="Beautiful Sundarban tour packages with Kolkata pickup, forest permits, boat safari, Bengali meals and guided wildlife experiences.">
  <link rel="stylesheet" href="/css/mainpage.css">
</head>

<body>
  <a class="skip-link" href="#main-content">Skip to main content</a>
  <nav class="navbar" id="mainNav">
    <div class="container nav-inner">
      <a class="brand" href="#top" aria-label="Sundarban Nova Travels home">
        <img src="/album/sundarban-nova-mark.png" alt="" class="brand-mark">
        <span>Sundarban Nova Travels</span>
      </a>
      <button class="nav-toggle" id="navToggle" type="button" aria-label="Toggle navigation" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
      <div class="nav-menu" id="navLinks">
        <a href="#pickup">Pickup</a>
        <a href="#packages">Packages</a>
        <a href="#food">Cuisine</a>
        <a href="#destinations">Explore</a>
        <a href="#gallery">Gallery</a>
      </div>
      <div class="nav-actions">
        <a class="phone-pill" href="tel:<%= companyPhoneHref %>"><%= companyPhone %></a>
          <button class="btn btn-primary" data-modal="bookModal"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M6 2v4M18 2v4M3 10h18M5 5h14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Z"/></svg>Book now</button>
      </div>
    </div>
  </nav>

  <header class="hero" id="top">
    <div class="hero-media" role="img" aria-label="Boat safari in the Sundarbans"></div>
    <div class="container hero-content">
      <div class="hero-copy glass-panel">
        <div class="eyebrow" id="heroEyebrow">UNESCO World Heritage | West Bengal | Since 2018</div>
        <h1 id="heroTitle">Discover the wild, tidal beauty of the Sundarbans.</h1>
        <p id="heroText">Private and shared boat safaris, forest permits, Kolkata pickup, warm local hospitality, and memorable Bengali
          meals arranged end to end.</p>
        <div class="hero-actions">
          <button class="btn btn-gold" data-modal="bookModal"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M6 2v4M18 2v4M3 10h18M5 5h14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Z"/></svg>Plan my trip</button>
          <a class="btn btn-light" href="#packages">View Packages</a>
        </div>
      </div>
      <figure class="hero-picture glass-panel">
        <img
          src="/album/sundarban-river.jpg"
          alt="Peaceful boat journey through green waterways">
        <figcaption>
          <strong>Forest boat safari</strong>
          <span>Permits, meals and pickup handled by local experts.</span>
        </figcaption>
      </figure>
      <div class="hero-stats glass-panel" aria-label="Tour highlights">
        <div><strong>Real</strong><span>Guest feedback</span></div>
        <div><strong>Permits</strong><span>Forest and boat included</span></div>
        <div><strong>Pickup</strong><span>Kolkata, Canning, Godkhali</span></div>
        <div><strong>24/7</strong><span>Travel support by phone</span></div>
      </div>
    </div>
  </header>

  <main id="main-content">
    <section id="pickup">
      <div class="container">
        <div class="section-head split">
          <div>
            <span class="badge-soft">Seamless Logistics</span>
            <h2>Choose your departure. We handle the rest.</h2>
          </div>
          <p>AC transfers, permits, meals, guided boat safaris and stays are bundled into simple, transparent packages
            for couples, families and groups.</p>
        </div>
        <div class="pickup-grid">
          <article class="pickup-card">
            <div class="icon-bubble">K</div>
            <span class="mini-label">Most booked</span>
            <h3>Kolkata to Kolkata</h3>
            <p>Doorstep AC car, airport or Science City pickup, breakfast en route and a tour captain from start to
              finish.</p>
            <ul>
              <li>AC sedan, SUV or traveller</li>
              <li>Morning departure support</li>
              <li>Best for first-time visitors</li>
            </ul>
            <button class="btn btn-outline-dark" data-pickup="Kolkata to Kolkata" data-modal="bookModal">Select
              Pickup</button>
          </article>
          <article class="pickup-card">
            <div class="icon-bubble">C</div>
            <h3>Canning to Canning</h3>
            <p>Ideal for guests arriving by local train. Meet-and-greet, auto transfer and boat boarding are coordinated
              for you.</p>
            <ul>
              <li>Station assistance</li>
              <li>Quick route to Godkhali</li>
              <li>Budget friendly</li>
            </ul>
            <button class="btn btn-outline-dark" data-pickup="Canning to Canning" data-modal="bookModal">Select
              Pickup</button>
          </article>
          <article class="pickup-card accent">
            <div class="icon-bubble">G</div>
            <span class="mini-label">Direct jetty</span>
            <h3>Godkhali to Godkhali</h3>
            <p>For self-drive guests who want secure parking, the fastest boarding and flexible check-in at the jetty.
            </p>
            <ul>
              <li>Reserved jetty slot</li>
              <li>Sunrise check-in available</li>
              <li>Custom timing support</li>
            </ul>
            <button class="btn btn-gold" data-pickup="Godkhali to Godkhali" data-modal="bookModal">Customize
              Pickup</button>
          </article>
        </div>
      </div>
    </section>

    <section id="packages" class="soft-section">
      <div class="container">
        <div class="section-head center">
          <span class="badge-soft">Signature Itineraries</span>
          <h2>Ten journeys crafted for real Sundarban days.</h2>
          <p>Every package includes a licensed boat, forest permits, naturalist guidance, meals, RO water and clear
            inclusions.</p>
        </div>
        <div class="package-grid" id="packageGrid"></div>
      </div>
    </section>

    <section id="food">
      <div class="container food-layout">
        <div>
          <span class="badge-soft">Bengali Kitchen</span>
          <h2>A moving feast on the river.</h2>
          <p class="lead">Fresh catch, mustard oil tempering, clean kitchens and flexible veg, Jain and kids menus make
            the meals feel like part of the journey.</p>
          <div class="feature-grid">
            <div><strong>Hygienic Kitchen</strong><span>Sanitized daily</span></div>
            <div><strong>RO Water</strong><span>Unlimited refills</span></div>
            <div><strong>Fresh Cuisine</strong><span>Fish, prawn, chicken</span></div>
            <div><strong>Custom Meals</strong><span>Veg, Jain, kids</span></div>
          </div>
          <button class="btn btn-primary" data-modal="bookModal">Taste The Menu</button>
        </div>
        <div>
          <div class="menu-tabs" id="menuTabs"></div>
          <div class="menu-panel" id="menuPanel"></div>
        </div>
      </div>
    </section>

    <section id="destinations" class="soft-section">
      <div class="container">
        <div class="section-head center">
          <span class="badge-soft">13 Signature Points</span>
          <h2>Where the river makes the map.</h2>
        </div>
        <div class="dest-grid" id="destGrid"></div>
      </div>
    </section>

    <section id="gallery">
      <div class="container">
        <div class="section-head split">
          <div>
            <span class="badge-soft">Field Notes</span>
            <h2>Real light, real water, real memories.</h2>
          </div>
          <p>Tap any image to open the travel gallery.</p>
        </div>
        <div class="masonry" id="masonry"></div>
      </div>
    </section>

    <section id="reviews" class="soft-section">
      <div class="container">
        <div class="section-head split">
          <div>
            <span class="badge-soft">Guest Reviews</span>
            <h2>Stories from real travellers.</h2>
          </div>
        </div>
        <div class="review-grid" id="reviewGrid"></div>
        <form class="review-form" id="reviewForm">
          <div><span class="badge-soft">Share your experience</span><h3>Travelled with us?</h3><p>Your honest review helps future guests plan with confidence.</p></div>
          <div class="form-grid"><label>Full Name<input required name="name" maxlength="60" autocomplete="name" placeholder="Your name"></label><label>Email<input required name="email" type="email" autocomplete="email" placeholder="you@example.com"></label><label>Tour<select name="tour"><option>1 Day - Day Cruise</option><option>2D / 1N - Classic Mangrove</option><option>3D / 2N - Tiger Trail</option><option>4D / 3N - Grand Expedition</option><option>Another tour</option></select></label><label>Rating<select required name="rating"><option value="5">5 — Excellent</option><option value="4">4 — Very good</option><option value="3">3 — Good</option><option value="2">2 — Fair</option><option value="1">1 — Poor</option></select></label><label class="full">Your review<textarea required name="comment" minlength="15" maxlength="700" rows="4" placeholder="Tell future guests about your experience…"></textarea></label></div>
          <div><button class="btn btn-primary" type="submit">Submit review</button><p class="form-status" id="reviewStatus" role="status" aria-live="polite"></p></div>
        </form>
      </div>
    </section>

    <section id="faq">
      <div class="container faq-layout">
        <div>
          <span class="badge-soft">Support</span>
          <h2>Everything you ask before boarding.</h2>
          <p class="lead">Clear answers on safety, permits, food, cancellations and timing.</p>
          <div class="support-card">Need a human? <a href="tel:+919907947625">+91 99079 47625</a> answers quickly.</div>
        </div>
        <div id="faqAcc"></div>
      </div>
    </section>

  </main>

  <footer>
    <div class="container footer-grid">
      <div>
        <h3>Sundarban Nova Travels</h3>
        <p>Low-impact Sundarban expeditions with local crews, warm service and careful planning.</p>
      </div>
      <div>
        <h4>Explore</h4><a href="#packages">Packages</a><a href="#food">Food Menu</a><a href="#gallery">Gallery</a>
      </div>
      <div>
        <h4>Support</h4><a href="#pickup">Pickup Options</a><a href="#faq">FAQs</a><a href="tel:<%= companyPhoneHref %>">Call us</a>
      </div>
      <div>
        <h4>Contact</h4><a href="tel:<%= companyPhoneHref %>"><%= companyPhone %></a><a
          href="mailto:hello@sundarbannovatravels.com">hello@sundarbannovatravels.com</a><span>Godkhali Jetty, WB
          743370</span>
      </div>
    </div>
    <div class="container footer-bottom">© <span id="yr"></span> Sundarban Nova Travels. All rights reserved.</div>
  </footer>

  <div class="float-bar">
    <a class="float-btn call" href="tel:<%= companyPhoneHref %>" aria-label="Call us">Call</a>
  </div>

  <div id="lightbox">
    <button class="close-lightbox" type="button" onclick="closeLightbox()" aria-label="Close gallery">Close</button>
    <img src="" alt="Expanded Sundarban travel photo">
  </div>

  <div class="modal-overlay" id="bookModal">
    <div class="modal-box" role="dialog" aria-modal="true" aria-labelledby="bookTitle">
      <button class="close-btn" type="button" onclick="closeModal('bookModal')"
        aria-label="Close booking form">Close</button>
      <span class="badge-soft">Instant Quote</span>
      <h2 id="bookTitle">Book your Sundarban expedition</h2>
      <p>Your request is saved securely. Our team will contact you by phone or email.</p>
      <form id="bookingForm">
        <label>Package Interested<select id="b_pkg">
            <option>1 Day - Day Cruise Rs. 1,499</option>
            <option>2D / 1N - Classic Mangrove Rs. 3,999</option>
            <option>3D / 2N - Tiger Trail Rs. 6,499</option>
            <option>4D / 3N - Grand Expedition Rs. 8,999</option>
            <option>Family Special</option>
            <option>Couple Honeymoon</option>
            <option>Group / Student / Corporate</option>
            <option>Luxury Houseboat</option>
          </select></label>
        <div class="form-grid">
          <label>Full Name<input id="b_name" required autocomplete="name" placeholder="Your name"></label>
          <label>Phone Number<input id="b_phone" required type="tel" inputmode="tel" autocomplete="tel" placeholder="+91..."></label>
          <label class="full">Email for confirmation<input id="b_email" required type="email" autocomplete="email" placeholder="you@example.com"></label>
          <label>Travel Date
            <div class="date-picker" id="datePicker">
              <input id="b_date" required readonly placeholder="Choose a travel date" aria-haspopup="dialog" aria-expanded="false">
              <button class="date-trigger" type="button" aria-label="Choose travel date"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M6 2v4M18 2v4M3 10h18M5 5h14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Z"/></svg></button>
              <div class="calendar-popover" id="calendarPopover" role="dialog" aria-label="Choose a travel date"></div>
            </div>
          </label>
          <label>Number of Guests<input id="b_guests" type="number" min="1" max="100" value="2" required inputmode="numeric" placeholder="e.g. 4"></label>
          <label>Pickup<select id="b_pickup">
              <option>Kolkata to Kolkata</option>
              <option>Canning to Canning</option>
              <option>Godkhali to Godkhali</option>
              <option>Custom</option>
            </select></label>
          <label>Food Preference<select id="b_food">
              <option>Bengali Non-Veg</option>
              <option>Veg</option>
              <option>Jain Veg</option>
              <option>Kids Meal</option>
            </select></label>
          <label class="full">Message<textarea id="b_msg" rows="2"
              placeholder="Any special request?"></textarea></label>
        </div>
        <label class="consent"><input id="b_marketing" type="checkbox"> Send me occasional tour offers and travel updates.</label>
        <p class="form-status" id="bookingStatus" role="status" aria-live="polite"></p>
        <button type="submit" class="btn btn-primary"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M6 2v4M18 2v4M3 10h18M5 5h14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Z"/></svg>Request booking</button>
      </form>
    </div>
  </div>

  <div class="toast" id="toast" role="status" aria-live="polite"></div>

  <div class="success-overlay" id="successOverlay" role="dialog" aria-modal="true" aria-labelledby="successTitle">
    <div class="success-card"><div class="success-icon">✓</div><span class="badge-soft">Request received</span><h2 id="successTitle">Your Sundarban journey starts here.</h2><p>Your booking request was submitted successfully. Our team will contact you soon to confirm the availability and next steps.</p><a class="success-contact" href="tel:<%= companyPhoneHref %>">Need help now? Call <%= companyPhone %></a><button class="btn btn-primary" type="button" id="successClose">Continue exploring</button></div>
  </div>

  <script src="/js/mainpagenew.js"></script>
</body>

</html>
